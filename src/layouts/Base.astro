---
const { title = 'Kinder Sefarim Bibliography', description = "A scholarly catalog of Orthodox Jewish children's literature." } = Astro.props;
---
<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Lora:ital,wght@0,400;0,500;0,600;0,700;1,400;1,500&family=Source+Sans+3:wght@400;500;600;700&display=swap"
      rel="stylesheet"
    />
    <style is:global>
      body { margin: 0; background: #e9e5dd; font-family: 'Source Sans 3', sans-serif; }
      a { color: #8a5a12; text-decoration: none; }
      a:hover { color: #6b450d; }
      input { font-family: 'Source Sans 3', sans-serif; }
      ::placeholder { color: rgba(23, 35, 58, 0.4); }
      * { box-sizing: border-box; }
    </style>
  </head>
  <body>
    <slot />
  </body>
</html>
