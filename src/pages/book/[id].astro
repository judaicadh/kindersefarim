---
import Base from '../../layouts/Base.astro';
import Nav from '../../components/Nav.astro';
import { getBooks, typeForm, linkifyByline, slugify, seriesKey } from '../../lib/sheet.js';

export async function getStaticPaths() {
  const { books } = await getBooks();
  return books.map((b) => ({ params: { id: b.id }, props: { book: b } }));
}

const { book: b } = Astro.props;
const tf = typeForm(b);
const bylineHtml = linkifyByline(b.byline, b.creators);
const seriesName = seriesKey(b.series);
---

<Base title={`${b.title} — Kinder Sefarim Bibliography`} description={b.summary || b.title}>
  <div style="min-height:100vh;background:#faf6ee">
    <Nav active="browse" />

    <!-- breadcrumb -->
    <div style="padding:15px 44px;border-bottom:1px solid rgba(23,35,58,.12);font:500 12px 'Source Sans 3',sans-serif;color:rgba(23,35,58,.5)">
      <a href="/" style="color:#8a5a12">Browse</a> &nbsp;›&nbsp; <span style="color:#17233a">{b.title}</span>
    </div>

    <div style="display:flex;gap:44px;padding:40px 44px 56px;max-width:1000px">
      <div style="width:214px;flex:none">
        <div style="width:100%;height:290px;background:repeating-linear-gradient(115deg,#dcd2ba,#dcd2ba 8px,#eee3c9 8px,#eee3c9 16px);border-radius:3px;box-shadow:0 2px 6px rgba(0,0,0,.15);display:flex;align-items:center;justify-content:center">
          <span style="font:500 10px ui-monospace,Menlo,monospace;color:rgba(23,35,58,.4);background:rgba(250,246,238,.85);padding:2px 6px;border-radius:2px">cover image</span>
        </div>
      </div>
      <div style="flex:1;max-width:660px">
        <div style="font:600 30px/1.22 'Lora',serif;color:#17233a">{b.title}</div>
        <div style="font:italic 400 16px 'Lora',serif;color:rgba(23,35,58,.65);margin-top:6px" set:html={bylineHtml}></div>

        <div style="display:flex;margin-top:18px;background:#fff;border:1px solid rgba(23,35,58,.16);border-radius:4px;overflow:hidden">
          <div style="flex:1;padding:12px 18px;border-right:1px solid rgba(23,35,58,.1)">
            <div style="font:600 9.5px 'Source Sans 3',sans-serif;letter-spacing:.06em;text-transform:uppercase;color:rgba(23,35,58,.45)">Publisher</div>
            <div style="font:500 13.5px 'Lora',serif;color:#17233a;margin-top:3px">
              {b.publisher && b.publisher !== '—'
                ? <a href={`/publishers/${slugify(b.publisher)}/`} style="color:#8a5a12">{b.publisher}</a>
                : b.publisher}
            </div>
          </div>
          <div style="flex:none;width:110px;padding:12px 18px;border-right:1px solid rgba(23,35,58,.1)">
            <div style="font:600 9.5px 'Source Sans 3',sans-serif;letter-spacing:.06em;text-transform:uppercase;color:rgba(23,35,58,.45)">Year</div>
            <div style="font:500 13.5px 'Lora',serif;color:#17233a;margin-top:3px">{b.year}</div>
          </div>
          <div style="flex:none;width:120px;padding:12px 18px">
            <div style="font:600 9.5px 'Source Sans 3',sans-serif;letter-spacing:.06em;text-transform:uppercase;color:rgba(23,35,58,.45)">Pages</div>
            <div style="font:500 13.5px 'Lora',serif;color:#17233a;margin-top:3px">{b.pages}</div>
          </div>
        </div>

        {b.summary && (
          <div style="font:400 14px/1.68 'Source Sans 3',sans-serif;color:#2a2a2a;margin-top:22px">{b.summary}</div>
        )}

        {b.subjects && b.subjects.length > 0 && (
          <div style="margin-top:22px">
            <div style="font:600 10px 'Source Sans 3',sans-serif;letter-spacing:.06em;text-transform:uppercase;color:rgba(23,35,58,.45);margin-bottom:10px">Subjects</div>
            <div style="display:flex;gap:7px;flex-wrap:wrap">
              {b.subjects.map((s) => (
                <a href={`/?subject=${encodeURIComponent(s)}`} style="font:500 11.5px 'Source Sans 3',sans-serif;color:#7a5a1e;background:#f2e6c4;border:1px solid rgba(122,90,30,.25);padding:5px 11px;border-radius:3px;cursor:pointer">{s}</a>
              ))}
            </div>
          </div>
        )}

        <div style="margin-top:26px;background:#fff;border:1px solid rgba(23,35,58,.16);border-radius:4px;padding:20px 22px">
          <div style="font:600 10px 'Source Sans 3',sans-serif;letter-spacing:.06em;text-transform:uppercase;color:rgba(23,35,58,.45);margin-bottom:14px">Full record</div>
          <div style="display:grid;grid-template-columns:130px 1fr 120px 1fr;gap:11px 22px;font:400 12.5px/1.4 'Source Sans 3',sans-serif">
            <div style="color:rgba(23,35,58,.5)">Type / form</div><div style="color:#17233a">{tf}</div>
            <div style="color:rgba(23,35,58,.5)">Audience</div><div style="color:#17233a">{b.f_aud}</div>
            <div style="color:rgba(23,35,58,.5)">Language</div><div style="color:#17233a">{b.lang}</div>
            <div style="color:rgba(23,35,58,.5)">Series</div><div style="color:#17233a">{seriesName ? <a href={`/series/${slugify(seriesName)}/`} style="color:#8a5a12">{b.series}</a> : b.series}</div>
            <div style="color:rgba(23,35,58,.5)">Edition</div><div style="color:#17233a">{b.edition}</div>
            <div style="color:rgba(23,35,58,.5)">Size</div><div style="color:#17233a">{b.size}</div>
            <div style="color:rgba(23,35,58,.5)">ISBN</div><div style="color:#17233a">{b.isbn}</div>
            <div style="color:rgba(23,35,58,.5)">OCLC</div><div style="color:#17233a">{b.oclc}</div>
            <div style="color:rgba(23,35,58,.5)">LCCN</div><div style="color:#17233a">{b.lccn}</div>
            <div style="color:rgba(23,35,58,.5)">Call number</div><div style="color:#17233a">{b.callnum}</div>
          </div>
        </div>
      </div>
    </div>
  </div>
</Base>
