---
import Base from '../../layouts/Base.astro';
import Nav from '../../components/Nav.astro';
import { getBooks, buildPublishers } from '../../lib/sheet.js';

const { books } = await getBooks();
const publishers = buildPublishers(books);
---

<Base title="Publishers — Kinder Sefarim Bibliography">
  <div style="min-height:100vh;background:#faf6ee">
    <Nav active="publishers" />

    <div style="padding:34px 44px;background:linear-gradient(180deg,#f2ead9,#faf6ee)">
      <div style="font:600 27px/1.2 'Lora',serif;color:#17233a">Publishers</div>
      <div style="margin-top:8px;font:400 13px 'Source Sans 3',sans-serif;color:rgba(23,35,58,.6)">{publishers.length} publishers in the catalog</div>
    </div>

    <div style="padding:8px 44px 56px;max-width:820px">
      {publishers.map((p) => (
        <a
          href={`/publishers/${p.slug}/`}
          class="dir-row"
          style="display:flex;align-items:baseline;gap:14px;padding:13px 8px;border-bottom:1px solid rgba(23,35,58,.1);color:inherit"
        >
          <span style="flex:1;font:600 15px 'Lora',serif;color:#17233a">{p.name}</span>
          <span style="width:60px;text-align:right;font:400 11px ui-monospace,monospace;color:rgba(23,35,58,.45)">{p.books.length} {p.books.length === 1 ? 'title' : 'titles'}</span>
        </a>
      ))}
    </div>
  </div>

  <style is:global>
    .dir-row:hover { background: rgba(199, 154, 58, 0.08); }
  </style>
</Base>
