---
import Base from '../../layouts/Base.astro';
import Nav from '../../components/Nav.astro';
import BookList from '../../components/BookList.astro';
import { getBooks, buildCreators } from '../../lib/sheet.js';

export async function getStaticPaths() {
  const { books } = await getBooks();
  return buildCreators(books).map((c) => ({ params: { slug: c.slug }, props: { creator: c } }));
}

const { creator: c } = Astro.props;
---

<Base title={`${c.name} — Kinder Sefarim Bibliography`} description={`Books by ${c.name} in the catalog.`}>
  <div style="min-height:100vh;background:#faf6ee">
    <Nav active="authors" />

    <div style="padding:15px 44px;border-bottom:1px solid rgba(23,35,58,.12);font:500 12px 'Source Sans 3',sans-serif;color:rgba(23,35,58,.5)">
      <a href="/authors/" style="color:#8a5a12">Authors</a> &nbsp;›&nbsp; <span style="color:#17233a">{c.name}</span>
    </div>

    <div style="padding:34px 44px 8px;background:linear-gradient(180deg,#f2ead9,#faf6ee)">
      <div style="font:600 27px/1.2 'Lora',serif;color:#17233a">{c.name}</div>
      <div style="margin-top:8px;font:400 13px 'Source Sans 3',sans-serif;color:rgba(23,35,58,.6)">
        {c.roles.join(' · ')} &nbsp;·&nbsp; {c.books.length} {c.books.length === 1 ? 'title' : 'titles'}
      </div>
    </div>

    <div style="padding:14px 44px 56px;max-width:820px">
      <BookList books={c.books} />
    </div>
  </div>
</Base>
