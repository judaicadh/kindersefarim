---
import Base from '../../layouts/Base.astro';
import Nav from '../../components/Nav.astro';
import BookList from '../../components/BookList.astro';
import { getBooks, buildSeries } from '../../lib/sheet.js';

export async function getStaticPaths() {
  const { books } = await getBooks();
  return buildSeries(books).map((s) => ({ params: { slug: s.slug }, props: { series: s } }));
}

const { series: s } = Astro.props;
---

<Base title={`${s.name} — Kinder Sefarim Bibliography`} description={`Titles in the ${s.name} series.`}>
  <div style="min-height:100vh;background:#faf6ee">
    <Nav active="series" />

    <div style="padding:15px 44px;border-bottom:1px solid rgba(23,35,58,.12);font:500 12px 'Source Sans 3',sans-serif;color:rgba(23,35,58,.5)">
      <a href="/series/" style="color:#8a5a12">Series</a> &nbsp;›&nbsp; <span style="color:#17233a">{s.name}</span>
    </div>

    <div style="padding:34px 44px 8px;background:linear-gradient(180deg,#f2ead9,#faf6ee)">
      <div style="font:600 27px/1.2 'Lora',serif;color:#17233a">{s.name}</div>
      <div style="margin-top:8px;font:400 13px 'Source Sans 3',sans-serif;color:rgba(23,35,58,.6)">
        Series &nbsp;·&nbsp; {s.books.length} {s.books.length === 1 ? 'title' : 'titles'}
      </div>
    </div>

    <div style="padding:14px 44px 56px;max-width:820px">
      <BookList books={s.books} />
    </div>
  </div>
</Base>
